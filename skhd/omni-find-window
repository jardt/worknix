#!/usr/bin/env python3
import json
import subprocess
import sys

bundle_id = sys.argv[1]
field = sys.argv[2] if len(sys.argv) > 2 else "id"

try:
    raw = subprocess.check_output([
        "/opt/homebrew/bin/omniwmctl", "query", "windows", "--format", "json"
    ], stderr=subprocess.DEVNULL, text=True)
    data = json.loads(raw)
except Exception:
    sys.exit(0)

windows = data.get("result", {}).get("payload", {}).get("windows", [])
matches = [w for w in windows if w.get("app", {}).get("bundleId") == bundle_id]
if not matches:
    sys.exit(0)

# Prefer visible, then focused, otherwise first known managed window.
matches.sort(key=lambda w: (not w.get("isVisible", False), not w.get("isFocused", False)))
w = matches[0]

if field == "workspace":
    ws = w.get("workspace", {})
    print(ws.get("rawName") or ws.get("number") or ws.get("displayName") or "")
else:
    print(w.get("id", ""))
